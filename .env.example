RELAY_HOST=127.0.0.1
RELAY_PORT=8787
MOCK_MODE=false

# Gemini live testing
GEMINI_API_KEY=
GEMINI_EXPANSION_API_KEY=
GEMINI_CLUE_MODEL=gemini-2.5-flash
GEMINI_VALIDATOR_MODEL=gemini-2.5-flash
GEMINI_VILLAIN_MODEL=gemini-2.5-flash

# Rust module -> local relay
ARMORIQ_VERIFY_URL=http://127.0.0.1:8787/api/armoriq/verify

# Relay -> real ArmorIQ upstream
ARMORIQ_UPSTREAM_VERIFY_URL=https://customer-proxy.armoriq.ai
ARMORIQ_TOKEN_ISSUE_URL=https://customer-proxy.armoriq.ai/token/issue
ARMORIQ_API_KEY=
ARMORIQ_API_KEY_HEADER=x-api-key
ARMORIQ_USER_ID=
ARMORIQ_AGENT_ID=

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
